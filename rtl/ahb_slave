//////////////////////////////////////////////////////
//  AHB SLAVE DESIGN FILE //
//////////////////////////////////////////////////////



`define OKAY 2'b00

module ahb_slave(

input  logic        clk,
input  logic        hresetn,

input  logic [31:0] haddr,
input  logic [31:0] hwdata,
input  logic [2:0]  hsize,
input  logic [2:0]  hburst,
input  logic [1:0]  htrans,
input  logic        hwrite,
input  logic        hsel,

output logic [31:0] hrdata,
output logic [1:0]  hresp,
output logic        hready

);

//////////////////////////////////////////////////////////////
// MEMORY
//////////////////////////////////////////////////////////////

logic [7:0] mem [0:255];

//////////////////////////////////////////////////////////////
// PIPELINE REGISTERS (ADDRESS PHASE)
//////////////////////////////////////////////////////////////

logic [31:0] addr_reg;
logic        write_reg;
logic        sel_reg;

//////////////////////////////////////////////////////////////
// ADDRESS PHASE CAPTURE
//////////////////////////////////////////////////////////////

always_ff @(posedge clk or negedge hresetn)
begin
   if(!hresetn)
   begin
      addr_reg  <= 32'h0;
      write_reg <= 1'b0;
      sel_reg   <= 1'b0;
   end
   else
   begin
      addr_reg  <= haddr;
      write_reg <= hwrite;
      sel_reg   <= hsel;
   end
end


//////////////////////////////////////////////////////////////
// MEMORY WRITE
//////////////////////////////////////////////////////////////

always_ff @(posedge clk or negedge hresetn)
begin
   if(!hresetn)
   begin
      for(int i=0;i<256;i++)
         mem[i] <= 8'h00;
   end
   else if(sel_reg && write_reg && addr_reg < 252)
   begin

      mem[addr_reg]   <= hwdata[7:0];
      mem[addr_reg+1] <= hwdata[15:8];
      mem[addr_reg+2] <= hwdata[23:16];
      mem[addr_reg+3] <= hwdata[31:24];

   end
end


//////////////////////////////////////////////////////////////
// MEMORY READ (DATA PHASE)
//////////////////////////////////////////////////////////////

always_ff @(posedge clk or negedge hresetn)
begin
   if(!hresetn)
      hrdata <= 32'h0;

   else if(sel_reg && !write_reg && addr_reg < 252)
   begin

      hrdata <= {

         mem[addr_reg+3],
         mem[addr_reg+2],
         mem[addr_reg+1],
         mem[addr_reg]

      };

   end
end


//////////////////////////////////////////////////////////////
// RESPONSE SIGNALS
//////////////////////////////////////////////////////////////

always_comb
begin
   hready = 1'b1;
   hresp  = `OKAY;
end


endmodule





