`include "ahb_interface.sv"
`include "ahb_pkg.sv"

import ahb_pkg::*;

module testbench;

   ////////////////////////////////////////////////////////////
   // INTERFACE INSTANCE
   ////////////////////////////////////////////////////////////

   ahb_interface vif();


   ////////////////////////////////////////////////////////////
   // DUT INSTANCE
   ////////////////////////////////////////////////////////////

   ahb_slave dut(

      .clk     (vif.clk),
      .hresetn (vif.hresetn),

      .haddr   (vif.haddr),
      .hwdata  (vif.hwdata),
      .hsize   (vif.hsize),
      .hburst  (vif.hburst),
      .htrans  (vif.htrans),
      .hwrite  (vif.hwrite),
      .hsel    (vif.hsel),

      .hrdata  (vif.hrdata),
      .hresp   (vif.hresp),
      .hready  (vif.hready)

   );


   ////////////////////////////////////////////////////////////
   // CLOCK GENERATION
   ////////////////////////////////////////////////////////////

   initial
   begin

      vif.clk = 0;

      forever #5 vif.clk = ~vif.clk;

   end


   ////////////////////////////////////////////////////////////
   // WAVEFORM DUMP (EDA Playground)
   ////////////////////////////////////////////////////////////

   initial
   begin

      $dumpfile("ahb_wave.vcd");
      $dumpvars(0,testbench);

   end


   ////////////////////////////////////////////////////////////
   // TEST EXECUTION
   ////////////////////////////////////////////////////////////

   ahb_test test_h;

   initial
   begin

      test_h = new(vif);

      test_h.build_and_run();

   end


endmodule
